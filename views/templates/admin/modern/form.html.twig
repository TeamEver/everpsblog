{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.css">
  <style>
    .ever-form-shell {
      --ever-primary: #4f46e5;
      --ever-primary-strong: #4338ca;
      --ever-primary-50: #eef2ff;
      --ever-accent: #0ea5e9;
      --ever-border: #e5e7eb;
      --ever-bg: #f8fafc;
      --ever-soft-text: #6b7280;
      background: var(--ever-bg);
      border: 1px solid var(--ever-border);
      border-radius: 16px;
      padding: 1.5rem;
      color: #111827;
    }

    .ever-form-hero {
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 60%, #0ea5e9 100%);
      color: #fff;
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 20px 55px -30px rgba(79, 70, 229, .55);
      margin-bottom: 1.25rem;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
    }
    .ever-form-hero h1 { margin: 0; font-size: 1.3rem; font-weight: 700; }
    .ever-form-hero p { margin: .25rem 0 0; opacity: .9; font-size: .9rem; }

    .ever-form-card {
      border: 1px solid var(--ever-border);
      border-radius: 14px;
      background: #fff;
      box-shadow: 0 20px 45px -35px rgba(15, 23, 42, .3);
      overflow: hidden;
    }

    .ever-form-card .card-header {
      border-bottom: 1px solid var(--ever-border);
      background: #fff;
      padding: 1rem 1.25rem;
      font-weight: 700;
      font-size: 1.05rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .65rem;
      flex-wrap: wrap;
    }

    .ever-form-card .card-body {
      padding: 1.25rem;
    }

    .ever-form-topbar {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: .8rem;
      margin-bottom: 1rem;
    }

    .ever-form-topbar .btn-group {
      display: flex;
      gap: .35rem;
      background: #fff;
      border: 1px solid var(--ever-border);
      border-radius: 999px;
      padding: .3rem;
      flex-wrap: wrap;
    }
    .ever-form-topbar .btn-group .btn {
      border-radius: 999px !important;
      font-weight: 600;
      padding: .45rem 1rem;
      border: none !important;
      background: transparent !important;
      color: #374151 !important;
      transition: all .15s ease;
    }
    .ever-form-topbar .btn-group .btn:hover {
      background: var(--ever-primary-50) !important;
      color: var(--ever-primary-strong) !important;
    }
    .ever-form-topbar .btn-group .btn-primary {
      background: linear-gradient(120deg, var(--ever-primary), var(--ever-accent)) !important;
      color: #fff !important;
    }
    .ever-form-topbar .btn-success {
      background: #10b981;
      border-color: #10b981;
      border-radius: 999px;
      font-weight: 700;
      padding: .5rem 1.25rem;
    }

    .ever-section-tabs {
      border: 1px solid var(--ever-border);
      border-radius: 999px;
      padding: .3rem;
      background: #fff;
      display: inline-flex;
      width: auto;
    }

    .ever-section-tabs .nav-tabs {
      border: none !important;
      margin: 0;
      flex-wrap: nowrap;
    }

    .ever-section-tabs .nav-link {
      border-radius: 999px !important;
      color: #374151;
      font-weight: 600;
      border: none !important;
      margin-right: .25rem;
      padding: .5rem 1.1rem;
      white-space: nowrap;
    }
    .ever-section-tabs .nav-link:hover {
      background: var(--ever-primary-50);
      color: var(--ever-primary-strong);
    }

    .ever-section-tabs .nav-link.active {
      background: linear-gradient(120deg, var(--ever-primary), var(--ever-accent));
      color: #fff !important;
      border: none !important;
    }

    .ever-lang-box,
    .ever-validation-box {
      border: 1px solid var(--ever-border);
      border-radius: 10px;
      background: #f9fafb;
      padding: .75rem 1rem;
      margin-top: .85rem;
    }

    .ever-lang-switch.active {
      background: var(--ever-primary) !important;
      border-color: var(--ever-primary) !important;
      color: #fff !important;
    }

    .ever-editorial-pane {
      border: 1px solid var(--ever-border);
      border-radius: 12px;
      background: #fff;
      padding: 1.25rem;
      margin-top: .85rem;
    }

    .ever-seo-field {
      border: 1px solid #f1f5f9;
      border-radius: 10px;
      background: #fafbff;
      padding: 1rem;
      margin-bottom: .8rem;
    }

    .ever-featured-image-preview {
      display: block;
      margin-top: .5rem;
    }
    .ever-featured-image-preview img {
      display: block;
      max-width: 320px;
      max-height: 180px;
      height: auto;
      border: 1px solid var(--ever-border);
      border-radius: 10px;
      margin-bottom: .45rem;
      background: #fff;
      cursor: zoom-in;
    }

    .ever-image-preview-modal {
      position: fixed;
      inset: 0;
      background: rgba(17, 24, 39, .75);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1060;
      padding: 1.5rem;
    }

    .ever-image-preview-modal.is-open {
      display: flex;
    }

    .ever-image-preview-modal img {
      display: block;
      max-width: min(1100px, 92vw);
      max-height: 88vh;
      border-radius: 10px;
      box-shadow: 0 35px 80px -40px rgba(0, 0, 0, .9);
      background: #fff;
    }

    .ever-image-preview-modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      border: 0;
      width: 2rem;
      height: 2rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .95);
      color: #111827;
      font-size: 1.2rem;
      line-height: 1;
      font-weight: 700;
      cursor: pointer;
    }

    .ever-admin-form .form-control-label,
    .ever-admin-form .col-form-label,
    .ever-admin-form label {
      font-weight: 600;
      color: #374151;
      font-size: .9rem;
    }
    .ever-admin-form input[type="text"],
    .ever-admin-form input[type="number"],
    .ever-admin-form input[type="url"],
    .ever-admin-form input[type="email"],
    .ever-admin-form input[type="password"],
    .ever-admin-form input[type="date"],
    .ever-admin-form input[type="datetime-local"],
    .ever-admin-form select,
    .ever-admin-form textarea {
      border: 1px solid var(--ever-border) !important;
      border-radius: 8px !important;
      padding: .55rem .75rem !important;
      font-size: .92rem !important;
      background: #fff !important;
      transition: border-color .15s, box-shadow .15s;
      box-shadow: none !important;
    }
    .ever-admin-form input:focus,
    .ever-admin-form select:focus,
    .ever-admin-form textarea:focus {
      outline: none !important;
      border-color: var(--ever-primary) !important;
      box-shadow: 0 0 0 3px rgba(79, 70, 229, .15) !important;
    }

    .ever-actions {
      border-top: 1px solid var(--ever-border);
      margin-top: 1.25rem;
      padding-top: 1.25rem;
    }

    .ever-actions .btn {
      font-weight: 700;
      border-radius: 8px;
      padding: .55rem 1.1rem;
      font-size: .9rem;
    }
    .ever-actions .btn-primary {
      background: var(--ever-primary);
      border-color: var(--ever-primary);
    }
    .ever-actions .btn-primary:hover {
      background: var(--ever-primary-strong);
      border-color: var(--ever-primary-strong);
    }
    .ever-actions .btn-success {
      background: #10b981;
      border-color: #10b981;
    }

    .ever-chip {
      background: var(--ever-primary-50);
      color: var(--ever-primary-strong);
      border-radius: 999px;
      padding: .22rem .7rem;
      font-size: .76rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .03em;
    }

    /* flatpickr fine-tuning */
    .flatpickr-calendar { font-family: inherit; border-radius: 10px; }
    .flatpickr-day.selected { background: var(--ever-primary); border-color: var(--ever-primary); }
  </style>
{% endblock %}

{% block ever_blog_form_header %}
  <div class="ever-form-topbar">
    <div class="btn-group" role="group" aria-label="{{ 'Ever Blog navigation'|trans({}, 'Modules.Everpsblog.Admin') }}">
      {% for link in navigationLinks %}
        <a class="btn {{ currentResource == link.key ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ link.url }}">{{ link.label|trans({}, 'Modules.Everpsblog.Admin') }}</a>
      {% endfor %}
    </div>
    {% if createUrl is defined and createUrl %}
      <a class="btn btn-success" href="{{ createUrl }}">{{ 'Add item'|trans({}, 'Modules.Everpsblog.Admin') }}</a>
    {% endif %}
  </div>
{% endblock %}

{% block ever_blog_form_tabs_nav %}
  <div class="ever-section-tabs">
    <ul class="nav nav-tabs border-0" role="tablist">
      <li class="nav-item"><a class="nav-link active" id="ever-tab-content" data-toggle="tab" href="#ever-pane-content" role="tab">{{ 'Content'|trans({}, 'Modules.Everpsblog.Admin') }}</a></li>
      <li class="nav-item"><a class="nav-link" id="ever-tab-seo" data-toggle="tab" href="#ever-pane-seo" role="tab">{{ 'SEO'|trans({}, 'Modules.Everpsblog.Admin') }}</a></li>
      <li class="nav-item"><a class="nav-link" id="ever-tab-publication" data-toggle="tab" href="#ever-pane-publication" role="tab">{{ 'Publication'|trans({}, 'Modules.Everpsblog.Admin') }}</a></li>
      <li class="nav-item"><a class="nav-link" id="ever-tab-relations" data-toggle="tab" href="#ever-pane-relations" role="tab">{{ 'Relations'|trans({}, 'Modules.Everpsblog.Admin') }}</a></li>
    </ul>
  </div>
{% endblock %}

{% block ever_blog_language_switch %}
  {% if everBlogLanguages is not empty %}
    <div class="ever-lang-box d-flex flex-wrap align-items-center justify-content-start">
      <div class="small text-muted mr-2">{{ 'Editing language:'|trans({}, 'Modules.Everpsblog.Admin') }}</div>
      <div class="btn-group btn-group-sm" role="group" aria-label="{{ 'Language selector'|trans({}, 'Modules.Everpsblog.Admin') }}">
        {% for lang in everBlogLanguages %}
          <button type="button" class="btn btn-outline-secondary ever-lang-switch {{ loop.first ? 'active' : '' }}" data-lang-id="{{ lang.id }}" title="{{ lang.name|default(lang.label) }}">{{ lang.label }}</button>
        {% endfor %}
      </div>
    </div>
  {% endif %}
{% endblock %}

{% block ever_blog_multilang_errors %}{% endblock %}

{% block ever_blog_post %}
  {{ block('ever_blog_editorial_layout') }}
{% endblock %}

{% block ever_blog_category %}
  {{ block('ever_blog_editorial_layout') }}
{% endblock %}

{% block ever_blog_tag %}
  {{ block('ever_blog_editorial_layout') }}
{% endblock %}

{% block ever_blog_author %}
  {{ block('ever_blog_editorial_layout') }}
{% endblock %}

{% block ever_blog_editorial_layout %}
  {{ block('ever_blog_form_tabs_nav') }}
  {{ block('ever_blog_language_switch') }}

  <div class="tab-content ever-editorial-pane">
    <div class="tab-pane fade show active" id="ever-pane-content" role="tabpanel">
      {% for field in everBlogSections.content %}
        {{ form_row(field) }}
      {% endfor %}
    </div>

    <div class="tab-pane fade" id="ever-pane-seo" role="tabpanel">
      {% for field in everBlogSections.seo %}
        {% set fieldName = field.vars.name %}
        {% set fieldLangIdFromName = field.vars.name|split('_')|last %}
        {% set fieldLangIdFromId = field.vars.id|split('_')|last %}
        {% set fieldLangId = fieldLangIdFromName matches '/^\d+$/' ? fieldLangIdFromName : (fieldLangIdFromId matches '/^\d+$/' ? fieldLangIdFromId : null) %}
        <div class="ever-seo-field {% if fieldName starts with 'meta_title_' %}ever-meta-title{% elseif fieldName starts with 'meta_description_' %}ever-meta-description{% elseif fieldName starts with 'link_rewrite_' %}ever-slug-field{% endif %}"{% if fieldLangId %} data-lang-id="{{ fieldLangId }}"{% endif %}>
          {{ form_row(field) }}
          {% if fieldName starts with 'meta_title_' %}
            <small class="form-text text-muted">
              <span data-counter-for="{{ field.vars.id }}">0</span>/70 {{ 'characters'|trans({}, 'Modules.Everpsblog.Admin') }}
            </small>
          {% elseif fieldName starts with 'meta_description_' %}
            <small class="form-text text-muted">
              <span data-counter-for="{{ field.vars.id }}">0</span>/160 {{ 'characters'|trans({}, 'Modules.Everpsblog.Admin') }}
            </small>
          {% elseif fieldName starts with 'link_rewrite_' %}
            <div class="d-flex justify-content-end mb-2">
              <button type="button" class="btn btn-sm btn-outline-secondary ever-generate-slug" data-target="{{ field.vars.id }}" data-lang-id="{{ field.vars.id|split('_')|last }}">
                {{ 'Auto-generate slug'|trans({}, 'Modules.Everpsblog.Admin') }}
              </button>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="tab-pane fade" id="ever-pane-publication" role="tabpanel">
      {% if everBlogSections.publication is empty %}
        <p class="text-muted mb-0">{{ 'No publication setting is available for this resource.'|trans({}, 'Modules.Everpsblog.Admin') }}</p>
      {% else %}
        {% for field in everBlogSections.publication %}
          {{ form_row(field) }}
        {% endfor %}
      {% endif %}
    </div>

    <div class="tab-pane fade" id="ever-pane-relations" role="tabpanel">
      {% if everBlogSections.relations is empty %}
        <p class="text-muted mb-0">{{ 'No configurable relation is available for this resource.'|trans({}, 'Modules.Everpsblog.Admin') }}</p>
      {% else %}
        {% for field in everBlogSections.relations %}
          {{ form_row(field) }}
        {% endfor %}
      {% endif %}
    </div>
  </div>
{% endblock %}

{% block ever_blog_form_actions %}
  <div class="ever-actions d-flex flex-wrap align-items-center">
    <a class="btn btn-outline-secondary mr-2 mb-2" href="{{ cancelUrl }}">{{ 'Cancel'|trans({}, 'Modules.Everpsblog.Admin') }}</a>
    <button type="submit" class="btn btn-success mr-2 mb-2" name="_submit_action" value="save">{{ 'Save'|trans({}, 'Modules.Everpsblog.Admin') }}</button>
    <button type="submit" class="btn btn-primary mb-2" name="_submit_action" value="save_and_stay">{{ 'Save and stay'|trans({}, 'Modules.Everpsblog.Admin') }}</button>
  </div>
{% endblock %}

{% block content %}
  {% set contentFields = [] %}
  {% set seoFields = [] %}
  {% set publicationFields = [] %}
  {% set relationFields = [] %}
  {% set otherFields = [] %}
  {% set langIds = [] %}

  {% set hasPostTabs = form.content_tab is defined or form.seo_tab is defined or form.publication_tab is defined or form.taxonomy_tab is defined %}

  {% if hasPostTabs %}
    {% if form.content_tab is defined %}
      {% for child in form.content_tab %}
        {% set contentFields = contentFields|merge([child]) %}
      {% endfor %}
    {% endif %}
    {% if form.seo_tab is defined %}
      {% for child in form.seo_tab %}
        {% set seoFields = seoFields|merge([child]) %}
      {% endfor %}
    {% endif %}
    {% if form.publication_tab is defined %}
      {% for child in form.publication_tab %}
        {% set publicationFields = publicationFields|merge([child]) %}
      {% endfor %}
    {% endif %}
    {% if form.taxonomy_tab is defined %}
      {% for child in form.taxonomy_tab %}
        {% set relationFields = relationFields|merge([child]) %}
      {% endfor %}
    {% endif %}
  {% else %}
    {% for child in form %}
      {% set fieldName = child.vars.name %}
      {% if fieldName starts with 'title_' or fieldName starts with 'content_' or fieldName starts with 'bottom_content_' or fieldName starts with 'excerpt_' %}
        {% set contentFields = contentFields|merge([child]) %}
      {% elseif fieldName starts with 'meta_title_' or fieldName starts with 'meta_description_' or fieldName starts with 'link_rewrite_' %}
        {% set seoFields = seoFields|merge([child]) %}
      {% elseif fieldName in ['post_status', 'date_add', 'id_author', 'starred', 'psswd', 'featured_image_file', 'delete_featured_image', 'banner_image_file', 'delete_banner_image', 'author_image_file', 'delete_author_image', 'active', 'indexable', 'follow', 'id_parent_category', 'is_root_category', 'id_employee', 'twitter', 'facebook', 'linkedin', 'count'] %}
        {% set publicationFields = publicationFields|merge([child]) %}
      {% elseif fieldName in ['id_default_category', 'post_categories', 'post_tags', 'post_products', 'allowed_groups', 'category_products', 'tag_products', 'author_products'] %}
        {% set relationFields = relationFields|merge([child]) %}
      {% else %}
        {% set otherFields = otherFields|merge([child]) %}
      {% endif %}
    {% endfor %}

    {% if otherFields is not empty %}
      {% set contentFields = contentFields|merge(otherFields) %}
    {% endif %}
  {% endif %}

  {% for field in contentFields|merge(seoFields)|merge(publicationFields)|merge(relationFields) %}
    {% set matches = field.vars.name|split('_') %}
    {% set maybeLangId = matches|last %}
    {% if maybeLangId matches '/^\\d+$/' and maybeLangId not in langIds %}
      {% set langIds = langIds|merge([maybeLangId]) %}
    {% endif %}
  {% endfor %}

  {# Prefer the language list provided by the controller (real Prestashop iso_code).
     Fallback: derive labels from form field labels when the template is rendered
     outside of the modern controllers. #}
  {% set everBlogLanguagesFromController = everBlogLanguages is defined and everBlogLanguages is iterable ? everBlogLanguages : [] %}
  {% set everBlogLanguages = [] %}

  {% if everBlogLanguagesFromController is not empty %}
    {% for lang in everBlogLanguagesFromController %}
      {% set langIdStr = (lang.id|default('')) ~ '' %}
      {% if langIdStr != '' and (langIds is empty or langIdStr in langIds) %}
        {% set everBlogLanguages = everBlogLanguages|merge([{
          id: langIdStr,
          label: lang.label|default('L' ~ langIdStr),
          name: lang.name|default(lang.label|default('L' ~ langIdStr))
        }]) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if everBlogLanguages is empty %}
    {% set everBlogLanguageLabels = {} %}
    {% for field in contentFields|merge(seoFields)|merge(publicationFields)|merge(relationFields) %}
      {% set fieldNameParts = field.vars.name|split('_') %}
      {% set fieldIdParts = field.vars.id|split('_') %}
      {% set maybeLangIdFromName = fieldNameParts|last %}
      {% set maybeLangIdFromId = fieldIdParts|last %}
      {% set maybeLangId = maybeLangIdFromName matches '/^\\d+$/' ? maybeLangIdFromName : (maybeLangIdFromId matches '/^\\d+$/' ? maybeLangIdFromId : null) %}
      {% if maybeLangId %}
        {% set labelParts = field.vars.label|default('')|split('(') %}
        {% set labelSuffix = labelParts|length > 1 ? (labelParts|last|split(')')|first) : '' %}
        {% set languageLabel = labelSuffix ? labelSuffix|upper : 'Language #%id%'|trans({'%id%': maybeLangId}, 'Modules.Everpsblog.Admin') %}
        {% set everBlogLanguageLabels = everBlogLanguageLabels|merge({ (maybeLangId): languageLabel }) %}
      {% endif %}
    {% endfor %}
    {% for langId in langIds %}
      {% set everBlogLanguages = everBlogLanguages|merge([{ id: langId, label: everBlogLanguageLabels[langId]|default('Language #%id%'|trans({'%id%': langId}, 'Modules.Everpsblog.Admin')) }]) %}
    {% endfor %}
  {% endif %}

  {% set everBlogSections = {
    content: contentFields,
    seo: seoFields,
    publication: publicationFields,
    relations: relationFields
  } %}
  {% set resourceLabels = {
    'post': 'Post',
    'category': 'Category',
    'tag': 'Tag',
    'author': 'Author',
    'comment': 'Comment'
  } %}

  <div class="ever-form-shell">
    <section class="ever-form-hero">
      <div>
        <h1>{{ resourceLabels[resource]|default(resource|capitalize)|trans({}, 'Modules.Everpsblog.Admin') }} - {{ entityId ? 'Edit #%id%'|trans({'%id%': entityId}, 'Modules.Everpsblog.Admin') : 'Create'|trans({}, 'Modules.Everpsblog.Admin') }}</h1>
        <p>{{ 'Rich editing, date picker, multilingual validation and quick actions.'|trans({}, 'Modules.Everpsblog.Admin') }}</p>
      </div>
      <span class="ever-chip">{{ 'Ever Blog - Modern BO'|trans({}, 'Modules.Everpsblog.Admin') }}</span>
    </section>

    <div class="card ever-form-card" id="ever-admin-form-root">
      <div class="card-body ever-admin-form">
        {{ block('ever_blog_form_header') }}

        {{ form_start(form, {'attr': {'id': 'ever-modern-form', 'class': 'ever-admin-form'}}) }}
        {% if csrfTokenId is defined and csrfTokenId %}
          <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrfTokenId) }}">
        {% endif %}

        {% if resource == 'post' %}
          {{ block('ever_blog_post') }}
        {% elseif resource == 'category' %}
          {{ block('ever_blog_category') }}
        {% elseif resource == 'tag' %}
          {{ block('ever_blog_tag') }}
        {% elseif resource == 'author' %}
          {{ block('ever_blog_author') }}
        {% else %}
          {{ form_widget(form) }}
        {% endif %}

        {{ form_rest(form) }}
        {{ block('ever_blog_form_actions') }}
        {{ form_end(form, {'render_rest': false}) }}
      </div>
    </div>
  </div>

  {% if qcdPageBuilderTargets is defined and qcdPageBuilderTargets is not empty %}
  <script>
    window.everQcdPageBuilderTargets = window.everQcdPageBuilderTargets || {};
    window.everQcdPageBuilderTargets['ever-modern-form'] = {{ qcdPageBuilderTargets|json_encode|raw }};
  </script>
  {% endif %}

  <script>
    (function () {
      var root = document.getElementById('ever-admin-form-root');
      if (!root) {
        return;
      }

      function getInput(id) {
        return document.getElementById(id);
      }

      function getInputBySelector(selector) {
        return root.querySelector(selector);
      }

      function toSlug(value) {
        if (!value) {
          return '';
        }

        value = value.toString().trim().toLowerCase();
        if (value.normalize) {
          value = value.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        }
        value = value.replace(/[\/_,:;]/g, '-');

        return value
          .replace(/[^a-z0-9 -]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-+/, '')
          .replace(/-+$/, '');
      }

      function extractLangId(value) {
        if (!value) {
          return null;
        }

        var match = value.match(/_(\d+)(?:\]|$)/);
        return match ? match[1] : null;
      }

      function detectLangForField(field) {
        if (!field) {
          return null;
        }

        return extractLangId(field.getAttribute('name') || '') || extractLangId(field.id || '');
      }

      function updateCounter(input, counter) {
        if (!input || !counter) {
          return;
        }

        counter.textContent = (input.value || '').length;
      }

      var counterNodes = root.querySelectorAll('[data-counter-for]');
      Array.prototype.forEach.call(counterNodes, function (counter) {
        var input = getInput(counter.getAttribute('data-counter-for'));
        if (!input) {
          return;
        }

        updateCounter(input, counter);
        input.addEventListener('input', function () {
          updateCounter(input, counter);
        });
      });

      var slugButtons = root.querySelectorAll('.ever-generate-slug');
      Array.prototype.forEach.call(slugButtons, function (btn) {
        btn.addEventListener('click', function () {
          var target = getInput(btn.getAttribute('data-target'));
          var langId = extractLangId(btn.getAttribute('data-lang-id')) || btn.getAttribute('data-lang-id');
          var titleInput = getInputBySelector('[id$="_title_' + langId + '"]')
            || getInputBySelector('[id$="_meta_title_' + langId + '"]')
            || getInputBySelector('[id$="_nickhandle"]');
          if (!target || !titleInput) {
            return;
          }

          target.value = toSlug(titleInput.value || '');
          target.dispatchEvent(new Event('input', { bubbles: true }));
        });
      });

      var richFields = root.querySelectorAll('textarea');
      Array.prototype.forEach.call(richFields, function (field) {
        var name = (field.getAttribute('name') || '').toLowerCase();
        var id = (field.id || '').toLowerCase();
        if (
          name.indexOf('content') !== -1 ||
          name.indexOf('excerpt') !== -1 ||
          name.indexOf('bio') !== -1 ||
          id.indexOf('content') !== -1 ||
          id.indexOf('excerpt') !== -1 ||
          id.indexOf('bio') !== -1
        ) {
          field.classList.add('rte');
          field.setAttribute('data-ever-richtext', '1');
        }
      });

      var langSwitchers = root.querySelectorAll('.ever-lang-switch');
      var langErrorItems = root.querySelectorAll('.ever-lang-error-item');
      var fieldsWithLang = root.querySelectorAll('[name]');

      function setActiveLang(langId) {
        Array.prototype.forEach.call(langSwitchers, function (btn) {
          btn.classList.toggle('active', btn.getAttribute('data-lang-id') === langId);
        });

        Array.prototype.forEach.call(fieldsWithLang, function (field) {
          var lang = detectLangForField(field);
          var seoWrapper = field.closest('.ever-seo-field');
          var wrapper = seoWrapper || field.closest('.form-group, .form-control-group, .mb-3') || field.parentNode;
          if (!lang || !wrapper) {
            return;
          }

          if (seoWrapper && !seoWrapper.getAttribute('data-lang-id')) {
            seoWrapper.setAttribute('data-lang-id', lang);
          }

          wrapper.style.display = lang === langId ? '' : 'none';
        });

        Array.prototype.forEach.call(root.querySelectorAll('.ever-seo-field[data-lang-id]'), function (block) {
          block.style.display = block.getAttribute('data-lang-id') === langId ? '' : 'none';
        });
      }

      function refreshLangValidation() {
        Array.prototype.forEach.call(langErrorItems, function (item) {
          var langId = item.getAttribute('data-lang-id');
          var invalid = false;
          Array.prototype.forEach.call(fieldsWithLang, function (field) {
            var lang = detectLangForField(field);
            if (lang !== langId) {
              return;
            }
            if (field.hasAttribute('required') && !(field.value || '').trim()) {
              invalid = true;
            }
          });

          var okNode = item.querySelector('.ever-lang-valid');
          var badNode = item.querySelector('.ever-lang-invalid');
          if (okNode && badNode) {
            okNode.classList.toggle('d-none', invalid);
            badNode.classList.toggle('d-none', !invalid);
          }
        });
      }

      Array.prototype.forEach.call(langSwitchers, function (btn) {
        btn.addEventListener('click', function () {
          setActiveLang(btn.getAttribute('data-lang-id'));
          refreshLangValidation();
        });
      });

      if (langSwitchers.length) {
        setActiveLang(langSwitchers[0].getAttribute('data-lang-id'));
        refreshLangValidation();
      }

      root.addEventListener('input', function () {
        refreshLangValidation();
      });

      var previewModal = document.createElement('div');
      previewModal.className = 'ever-image-preview-modal';
      previewModal.setAttribute('aria-hidden', 'true');
      previewModal.innerHTML = '<button type="button" class="ever-image-preview-modal-close" aria-label="Close">&times;</button><img src="" alt="">';
      document.body.appendChild(previewModal);

      var previewImage = previewModal.querySelector('img');

      function closePreviewModal() {
        previewModal.classList.remove('is-open');
        previewModal.setAttribute('aria-hidden', 'true');
        previewImage.setAttribute('src', '');
      }

      function openPreviewModal(src, alt) {
        if (!src) {
          return;
        }

        previewImage.setAttribute('src', src);
        previewImage.setAttribute('alt', alt || '');
        previewModal.classList.add('is-open');
        previewModal.setAttribute('aria-hidden', 'false');
      }

      Array.prototype.forEach.call(root.querySelectorAll('.ever-featured-image-preview img'), function (imageNode) {
        imageNode.addEventListener('click', function () {
          openPreviewModal(imageNode.getAttribute('data-ever-preview-src') || imageNode.getAttribute('src'), imageNode.getAttribute('alt') || '');
        });
      });

      previewModal.addEventListener('click', function (event) {
        if (event.target === previewModal || event.target.classList.contains('ever-image-preview-modal-close')) {
          closePreviewModal();
        }
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          closePreviewModal();
        }
      });
    })();
  </script>

  {# TinyMCE rich text editor #}
  <script src="https://cdn.jsdelivr.net/npm/tinymce@6/tinymce.min.js" referrerpolicy="origin"></script>
  <script>
    (function () {
      var root = document.getElementById('ever-admin-form-root');
      if (!root || typeof tinymce === 'undefined') { return; }

      var everTinyMceUploadUrl = '{{ path('everpsblog_admin_tinymce_upload')|e('js') }}';
      var everTinyMceUploadToken = '{{ csrf_token('everpsblog_tinymce_upload')|e('js') }}';
      function everTinyMceImageUploadHandler(blobInfo, progress) {
        return new Promise(function (resolve, reject) {
          var xhr = new XMLHttpRequest();
          xhr.open('POST', everTinyMceUploadUrl);
          xhr.withCredentials = true;
          xhr.upload.onprogress = function (event) {
            if (event.lengthComputable && typeof progress === 'function') {
              progress(event.loaded / event.total * 100);
            }
          };
          xhr.onload = function () {
            var json;
            try {
              json = JSON.parse(xhr.responseText || '{}');
            } catch (error) {
              reject('Invalid upload response.');
              return;
            }
            if (xhr.status < 200 || xhr.status >= 300) {
              reject(json.error || 'Image upload failed.');
              return;
            }
            if (!json || typeof json.location !== 'string') {
              reject('Invalid upload response.');
              return;
            }
            resolve(json.location);
          };
          xhr.onerror = function () {
            reject('Image upload failed.');
          };

          var formData = new FormData();
          formData.append('_token', everTinyMceUploadToken);
          formData.append('file', blobInfo.blob(), blobInfo.filename());
          xhr.send(formData);
        });
      }

      var targets = root.querySelectorAll('textarea[data-ever-richtext="1"]');
      Array.prototype.forEach.call(targets, function (textarea) {
        if (!textarea.id) {
          textarea.id = 'ever-rte-' + Math.random().toString(36).slice(2, 10);
        }
        tinymce.init({
          target: textarea,
          license_key: 'gpl',
          promotion: false,
          branding: false,
          language: 'fr_FR',
          language_url: 'https://cdn.jsdelivr.net/npm/tinymce-i18n@24.11.11/langs7/fr_FR.js',
          height: 360,
          menubar: 'edit view insert format tools table',
          plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
          toolbar: 'undo redo | blocks | bold italic underline forecolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image media table | removeformat | code fullscreen',
          automatic_uploads: true,
          paste_data_images: true,
          images_upload_handler: everTinyMceImageUploadHandler,
          content_style: 'body { font-family:Inter,Helvetica,Arial,sans-serif; font-size:14px; }',
          setup: function (editor) {
            editor.on('change keyup', function () { editor.save(); });
          }
        });
      });
    })();
  </script>

  {# Flatpickr datetime picker #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/l10n/fr.min.js"></script>
  <script>
    (function () {
      var root = document.getElementById('ever-admin-form-root');
      if (!root || typeof flatpickr === 'undefined') { return; }

      if (flatpickr.l10ns && flatpickr.l10ns.fr) {
        flatpickr.localize(flatpickr.l10ns.fr);
      }

      var dateInputs = root.querySelectorAll(
        'input[type="date"], input[type="datetime-local"], ' +
        'input[name*="date"], input[name*="_at"], ' +
        'input[id*="date"], input[id*="_at"]'
      );
      Array.prototype.forEach.call(dateInputs, function (input) {
        if (input.dataset.everPicker === '1') { return; }
        input.dataset.everPicker = '1';

        var rawType = (input.getAttribute('type') || '').toLowerCase();
        var name = (input.getAttribute('name') || '').toLowerCase();
        var hasTime = rawType === 'datetime-local'
          || name.indexOf('datetime') !== -1
          || name.indexOf('_at') !== -1
          || name.indexOf('published') !== -1
          || name.indexOf('scheduled') !== -1;

        // Keep the browser-friendly value format
        if (rawType !== 'datetime-local' && rawType !== 'date') {
          input.setAttribute('type', 'text');
        }

        flatpickr(input, {
          enableTime: hasTime,
          time_24hr: true,
          dateFormat: hasTime ? 'Y-m-d H:i' : 'Y-m-d',
          altInput: true,
          altFormat: hasTime ? 'd/m/Y H:i' : 'd/m/Y',
          allowInput: true
        });
      });
    })();
  </script>
{% endblock %}
